# ── Site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nanofrogpro.com

# ── Lead storage (choose one: log | supabase | postgres | airtable) ─────
LEAD_STORE=log
# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Neon / Postgres
DATABASE_URL=
# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Leads

# ── Email notifications (Resend example) ───────────────────────────────
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=owner@nanofrogpro.com
LEAD_FROM_EMAIL=leads@nanofrogpro.com

# ── Spam protection (optional, Upstash rate limit) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── File uploads (optional cloud storage) ──────────────────────────────
UPLOAD_PROVIDER=local
# e.g. Supabase Storage / S3 keys go here when configured

# ── Analytics (public) ─────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=
