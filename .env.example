# ── Site ───────────────────────────────────────────────────────────────
# H2 (approved): canonical domain
NEXT_PUBLIC_SITE_URL=https://elytrashield.us
# Business phone for click-to-call (header/footer/CTA). Leave blank to hide.
# Example: NEXT_PUBLIC_PHONE=(478) 555-0123
NEXT_PUBLIC_PHONE=

# ── Supabase (auth + sales platform persistence) ──────────────────────
# Run `npm run verify:auth` after changing anything auth-related.
# When these are set, the sales platform saves to Supabase. When blank, it
# falls back to console logging / demo data (the app still runs).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=roof-passports

# ── Lead storage (choose one: supabase | airtable | log) ────────────────
# C2 (approved): leads may never exist only in logs. Set to "supabase" in
# production (uses SUPABASE_* vars above and the leads table in supabase/schema.sql).
# "log" is for local development only and warns on every submission.
LEAD_STORE=supabase
# (legacy) generic Postgres / Airtable options for the public lead forms
# Neon / Postgres
DATABASE_URL=
# Airtable
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Leads

# ── Email notifications (Resend example) ───────────────────────────────
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=owner@elytrashield.us
LEAD_FROM_EMAIL=leads@elytrashield.us

# ── Spam protection (optional, Upstash rate limit) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── File uploads (optional cloud storage) ──────────────────────────────
UPLOAD_PROVIDER=local
# e.g. Supabase Storage / S3 keys go here when configured

# ── Analytics (public) ─────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_META_PIXEL_ID=
